generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  EDITOR_IN_CHIEF
  MANAGING_EDITOR
  TEAM_LEAD
  REPORTER_TRANSLATOR
  CONTRIBUTOR
}

enum EditorialStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_PUBLISH
  PUBLISHED
  REJECTED
}

enum MediaAssetType {
  IMAGE
  VIDEO
}

enum MediaAssetVisibility {
  PRIVATE
  SHARED
}

model RolePermission {
  id        String   @id @default(cuid())
  role      UserRole
  action    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, action])
  @@index([role])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(CONTRIBUTOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  comments        Comment[]
  posts           Post[]
  approvedPosts   Post[]   @relation("PostApprover")
  lastEditedPosts Post[]   @relation("PostLastEditor")
  mediaAssets     MediaAsset[]
  postHistories   PostHistory[] @relation("UserPostHistory")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("Subcategories", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("Subcategories")
  sortOrder   Int        @default(0)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       Post[]
}

model Post {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String
  content        String
  penName        String?
  thumbnailUrl   String?
  videoEmbedUrl  String?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  ogImage        String?
  isSensitive    Boolean  @default(false)
  isDraft        Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  isTrending     Boolean  @default(false)
  isPublished    Boolean  @default(false)
  editorialStatus EditorialStatus @default(DRAFT)
  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?
  approvedAt     DateTime?
  views          Int      @default(0)
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  categoryId     String
  authorId       String?
  approverId     String?
  lastEditorId   String?
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  approver       User?    @relation("PostApprover", fields: [approverId], references: [id], onDelete: SetNull)
  lastEditor     User?    @relation("PostLastEditor", fields: [lastEditorId], references: [id], onDelete: SetNull)
  comments       Comment[]
  history        PostHistory[]
  seoKeywordLinks PostSeoKeyword[]
  engagementEvents PostEngagementEvent[]

  @@index([categoryId])
  @@index([authorId])
  @@index([approverId])
  @@index([lastEditorId])
  @@index([isDraft])
  @@index([isPublished, publishedAt(sort: Desc)])
  @@index([editorialStatus])
  @@index([isDeleted, isPublished, isDraft, publishedAt(sort: Desc)])
  @@index([isDeleted, isPublished, views(sort: Desc), publishedAt(sort: Desc)])
  @@index([categoryId, isDeleted, isPublished, publishedAt(sort: Desc)])
  @@index([editorialStatus, isDeleted, publishedAt(sort: Desc)])
  @@index([authorId, editorialStatus])
}

model MediaAsset {
  id          String               @id @default(cuid())
  publicId    String?
  assetType   MediaAssetType
  visibility  MediaAssetVisibility @default(SHARED)
  url         String
  displayName String?
  filename    String
  mimeType    String
  sizeBytes   Int
  uploadedAt  DateTime             @default(now())
  uploaderId  String
  uploader    User                 @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([uploaderId, assetType])
  @@index([visibility, assetType])
  @@index([uploadedAt])
}

model Comment {
  id         String   @id @default(cuid())
  authorName String
  content    String
  isApproved Boolean  @default(false)
  containsBlockedKeyword Boolean @default(false)
  createdAt  DateTime @default(now())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([authorId])
  @@index([isApproved, containsBlockedKeyword])
  @@index([postId, isApproved])
}

model SeoKeyword {
  id                String           @id @default(cuid())
  keyword           String
  normalizedKeyword String           @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  postLinks         PostSeoKeyword[]

  @@index([keyword])
}

model PostSeoKeyword {
  postId      String
  seoKeywordId String
  createdAt   DateTime   @default(now())
  post        Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  seoKeyword  SeoKeyword @relation(fields: [seoKeywordId], references: [id], onDelete: Cascade)

  @@id([postId, seoKeywordId])
  @@index([seoKeywordId])
}

model ForbiddenKeyword {
  id             String   @id @default(cuid())
  term           String
  normalizedTerm String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([term])
}

model PostEngagementEvent {
  id           String   @id @default(cuid())
  postId       String
  dwellSeconds Int
  createdAt    DateTime @default(now())
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([postId, createdAt])
}

model PostHistory {
  id              String           @id @default(cuid())
  postId          String
  actorId         String
  actionType      String           
  fromStatus      EditorialStatus?
  toStatus        EditorialStatus?
  snapshotTitle   String?
  snapshotExcerpt String?
  snapshotContent String?
  createdAt       DateTime         @default(now())

  post            Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor           User             @relation("UserPostHistory", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([postId, createdAt])
  @@index([actorId])
}
