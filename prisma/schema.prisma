generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  EDITOR_IN_CHIEF
  MANAGING_EDITOR
  TEAM_LEAD
  REPORTER_TRANSLATOR
  CONTRIBUTOR
}

enum EditorialStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_PUBLISH
  PUBLISHED
  REJECTED
}

enum MediaAssetType {
  IMAGE
  VIDEO
}

enum MediaAssetVisibility {
  PRIVATE
  SHARED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(CONTRIBUTOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  comments     Comment[]
  posts        Post[]
  approvedPosts Post[]   @relation("PostApprover")
  mediaAssets  MediaAsset[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("Subcategories", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("Subcategories")
  sortOrder   Int        @default(0)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       Post[]
}

model Post {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String
  content        String
  thumbnailUrl   String?
  videoEmbedUrl  String?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  ogImage        String?
  isSensitive    Boolean  @default(false)
  isDraft        Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  isTrending     Boolean  @default(false)
  isPublished    Boolean  @default(false)
  editorialStatus EditorialStatus @default(DRAFT)
  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?
  approvedAt     DateTime?
  views          Int      @default(0)
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  categoryId     String
  authorId       String?
  approverId     String?
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  approver       User?    @relation("PostApprover", fields: [approverId], references: [id], onDelete: SetNull)
  comments       Comment[]

  @@index([categoryId])
  @@index([authorId])
  @@index([approverId])
  @@index([isDraft])
  @@index([isPublished, publishedAt])
  @@index([editorialStatus])
  @@index([isDeleted])
  @@index([views])
}

model MediaAsset {
  id          String               @id @default(cuid())
  assetType   MediaAssetType
  visibility  MediaAssetVisibility @default(SHARED)
  url         String
  displayName String?
  filename    String
  mimeType    String
  sizeBytes   Int
  uploadedAt  DateTime             @default(now())
  uploaderId  String
  uploader    User                 @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([uploaderId, assetType])
  @@index([visibility, assetType])
  @@index([uploadedAt])
}

model Comment {
  id         String   @id @default(cuid())
  authorName String
  content    String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([authorId])
}
